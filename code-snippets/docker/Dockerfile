# база образа
FROM eclipse-temurin:17-jdk 

# рабочая папка
WORKDIR /app

# копирует файл из хоста в контейнер
# в нашем случае копирует app.jar => /app/app.jar по сути подставляет 
COPY app.jar app.jar

# Выполняемая команда. То, что оно в массиве - важно. Просто через " " не стоит делать
CMD ["java", "-jar", "app.jar"]